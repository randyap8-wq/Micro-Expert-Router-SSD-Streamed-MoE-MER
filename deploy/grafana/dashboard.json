{
  "title": "Micro-Expert Router",
  "schemaVersion": 38,
  "tags": ["mer", "moe"],
  "timezone": "browser",
  "refresh": "15s",
  "panels": [
    {
      "type": "graph",
      "title": "Requests / sec by status",
      "datasource": "Prometheus",
      "targets": [{
        "expr": "sum by (status) (rate(mer_requests_total[1m]))",
        "legendFormat": "{{status}}"
      }],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 }
    },
    {
      "type": "graph",
      "title": "p50 / p95 / p99 latency (s)",
      "datasource": "Prometheus",
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(mer_request_latency_seconds_bucket[5m]))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, rate(mer_request_latency_seconds_bucket[5m]))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, rate(mer_request_latency_seconds_bucket[5m]))", "legendFormat": "p99" }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 }
    },
    {
      "type": "graph",
      "title": "Tokens / sec",
      "datasource": "Prometheus",
      "targets": [{ "expr": "rate(mer_tokens_total[1m])" }],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 }
    },
    {
      "type": "graph",
      "title": "Expert cache hit ratio",
      "datasource": "Prometheus",
      "targets": [{
        "expr": "rate(mer_cache_hits_total[5m]) / (rate(mer_cache_hits_total[5m]) + rate(mer_cache_misses_total[5m]))"
      }],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 }
    },
    {
      "type": "graph",
      "title": "Paged-KV blocks in use",
      "datasource": "Prometheus",
      "targets": [
        { "expr": "mer_block_pool_in_use", "legendFormat": "in use" },
        { "expr": "mer_block_pool_free",    "legendFormat": "free" },
        { "expr": "mer_block_pool_overflow_in_use", "legendFormat": "overflow" }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 }
    },
    {
      "type": "graph",
      "title": "SSD read bandwidth (MiB/s)",
      "datasource": "Prometheus",
      "targets": [{ "expr": "rate(mer_bytes_read_total[1m]) / (1024*1024)" }],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 }
    },
    {
      "type": "graph",
      "title": "Speculator top-1 accuracy",
      "datasource": "Prometheus",
      "targets": [{
        "expr": "rate(mer_speculator_accuracy_total[5m]) / rate(mer_speculator_total[5m])"
      }],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 }
    },
    {
      "type": "stat",
      "title": "Expert read failures (since start)",
      "datasource": "Prometheus",
      "targets": [{ "expr": "mer_expert_read_failures_total" }],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 }
    }
  ]
}
